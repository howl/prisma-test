{
  "info": {
    "name": "Prisma Test API",
    "schema": "https://schema.postman.com/collection/json/v2.1.0/draft-07/collection.json"
  },
  "item": [
    {
      "name": "Clientes",
      "item": [
        {
          "name": "Listar clientes",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/clientes",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "clientes"
              ]
            }
          }
        },
        {
          "name": "Obtener cliente",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/clientes/{{clienteId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "clientes",
                "{{clienteId}}"
              ]
            }
          }
        },
        {
          "name": "Crear cliente",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Juan Pérez\",\n  \"correo\": \"juan@example.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/clientes",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "clientes"
              ]
            }
          }
        },
        {
          "name": "Crear cliente - correo duplicado",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Otro\",\n  \"correo\": \"juan@example.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/clientes",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "clientes"
              ]
            }
          }
        },
        {
          "name": "Actualizar cliente",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Juan Actualizado\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/clientes/{{clienteId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "clientes",
                "{{clienteId}}"
              ]
            }
          }
        },
        {
          "name": "Eliminar cliente",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/clientes/{{clienteId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "clientes",
                "{{clienteId}}"
              ]
            }
          }
        },
        {
          "name": "Cliente no encontrado",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/clientes/00000000-0000-0000-0000-000000000000",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "clientes",
                "00000000-0000-0000-0000-000000000000"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Eventos",
      "item": [
        {
          "name": "Listar eventos",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/eventos",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "eventos"
              ]
            }
          }
        },
        {
          "name": "Obtener evento",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/eventos/{{eventoId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "eventos",
                "{{eventoId}}"
              ]
            }
          }
        },
        {
          "name": "Crear evento",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Comprar leche\",\n  \"descripcion\": \"Ir al supermercado\",\n  \"clienteId\": \"{{clienteId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/eventos",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "eventos"
              ]
            }
          }
        },
        {
          "name": "Actualizar evento",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Comprar pan\",\n  \"completado\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/eventos/{{eventoId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "eventos",
                "{{eventoId}}"
              ]
            }
          }
        },
        {
          "name": "Eliminar evento",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/eventos/{{eventoId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "eventos",
                "{{eventoId}}"
              ]
            }
          }
        },
        {
          "name": "Evento no encontrado",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/eventos/00000000-0000-0000-0000-000000000000",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "eventos",
                "00000000-0000-0000-0000-000000000000"
              ]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "clienteId",
      "value": ""
    },
    {
      "key": "eventoId",
      "value": ""
    }
  ]
}
